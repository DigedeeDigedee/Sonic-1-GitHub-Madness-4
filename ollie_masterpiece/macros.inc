; ------------------------------------------------------------------------------
; Calculate VRAM write VDP command
; ------------------------------------------------------------------------------
; ARGUMENTS:
;	addr - VRAM address
; ------------------------------------------------------------------------------

ol_vramWriteCmd function addr,($40000000|(((addr)&$3FFF)<<16)|(((addr)&$C000)>>14))

; ------------------------------------------------------------------------------
; Calculate CRAM write VDP command
; ------------------------------------------------------------------------------
; ARGUMENTS:
;	addr - CRAM address
; ------------------------------------------------------------------------------

ol_cramWriteCmd function addr,($C0000000|(((addr)&$3FFF)<<16)|(((addr)&$C000)>>14))

; ------------------------------------------------------------------------------
; Calculate VSRAM write VDP command
; ------------------------------------------------------------------------------
; ARGUMENTS:
;	addr - VSRAM address
; ------------------------------------------------------------------------------

ol_vsramWriteCmd function addr,($40000010|(((addr)&$3FFF)<<16)|(((addr)&$C000)>>14))

; ------------------------------------------------------------------------------
; Calculate VRAM DMA VDP command
; ------------------------------------------------------------------------------
; ARGUMENTS:
;	addr - VRAM address
; ------------------------------------------------------------------------------

ol_vramDmaCmd function addr,($40000080|(((addr)&$3FFF)<<16)|(((addr)&$C000)>>14))

; ------------------------------------------------------------------------------
; Calculate CRAM DMA VDP command
; ------------------------------------------------------------------------------
; ARGUMENTS:
;	addr - CRAM address
; ------------------------------------------------------------------------------

ol_cramDmaCmd function addr,($C0000080|(((addr)&$3FFF)<<16)|(((addr)&$C000)>>14))

; ------------------------------------------------------------------------------
; Calculate VSRAM DMA VDP command
; ------------------------------------------------------------------------------
; ARGUMENTS:
;	addr - VSRAM address
; ------------------------------------------------------------------------------

ol_vsramDmaCmd function addr,($40000090|(((addr)&$3FFF)<<16)|(((addr)&$C000)>>14))

; ------------------------------------------------------------------------------
; Perform DMA from 68000 memory to VRAM
; ------------------------------------------------------------------------------
; ARGUMENTS:
;	src  - Source address
;	dest - Destination address
;	len  - Length
;	reg  - VDP control port
; ------------------------------------------------------------------------------

ol_dmaVram macro src, dest, len, ctrl
	move.w	#$9700|(((((src)>>1)&$FF0000)>>16)&$7F),ctrl
	move.l	#$96009500|((((src)>>1)&$FF00)<<8)|(((src)>>1)&$FF),ctrl
	move.l	#$94009300|((((len)>>1)&$FF00)<<8)|(((len)>>1)&$FF),ctrl
	move.w	#ol_vramDmaCmd(dest)>>16,ctrl
	move.w	#ol_vramDmaCmd(dest)&$FFFF,-(sp)
	move.w	(sp)+,ctrl
	endm

; ------------------------------------------------------------------------------
; Perform DMA from 68000 memory to CRAM
; ------------------------------------------------------------------------------
; ARGUMENTS:
;	src  - Source address
;	dest - Destination address
;	len  - Length
;	reg  - VDP control port
; ------------------------------------------------------------------------------

ol_dmaCram macro src, dest, len, ctrl
	move.w	#$9700|(((((src)>>1)&$FF0000)>>16)&$7F),ctrl
	move.l	#$96009500|((((src)>>1)&$FF00)<<8)|(((src)>>1)&$FF),ctrl
	move.l	#$94009300|((((len)>>1)&$FF00)<<8)|(((len)>>1)&$FF),ctrl
	move.w	#ol_cramDmaCmd(dest)>>16,ctrl
	move.w	#ol_cramDmaCmd(dest)&$FFFF,-(sp)
	move.w	(sp)+,ctrl
	endm

; ------------------------------------------------------------------------------
; Perform DMA from 68000 memory to VSRAM
; ------------------------------------------------------------------------------
; ARGUMENTS:
;	src  - Source address
;	dest - Destination address
;	len  - Length
;	reg  - VDP control port
; ------------------------------------------------------------------------------

ol_dmaVsram macro src, dest, len, ctrl
	move.w	#$9700|(((((src)>>1)&$FF0000)>>16)&$7F),ctrl
	move.l	#$96009500|((((src)>>1)&$FF00)<<8)|(((src)>>1)&$FF),ctrl
	move.l	#$94009300|((((len)>>1)&$FF00)<<8)|(((len)>>1)&$FF),ctrl
	move.w	#ol_vsramDmaCmd(dest)>>16,ctrl
	move.w	#ol_vsramDmaCmd(dest)&$FFFF,-(sp)
	move.w	(sp)+,ctrl
	endm

