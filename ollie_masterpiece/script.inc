; ------------------------------------------------------------------------------
; Script command IDs
; ------------------------------------------------------------------------------

	phase 0
ol_SCRIPT_TEXT		ds.b 1					; Draw text
ol_SCRIPT_WAIT_USER	ds.b 1					; Wait for user
ol_SCRIPT_SHOW_TEXTBOX	ds.b 1					; Show textbox
ol_SCRIPT_HIDE_TEXTBOX	ds.b 1					; Hide textbox
ol_SCRIPT_CLEAR_TEXTBOX	ds.b 1					; Clear textbox
ol_SCRIPT_SHOW_ICON	ds.b 1					; Show icon
ol_SCRIPT_HIDE_ICON	ds.b 1					; Hide icon
	dephase

; ------------------------------------------------------------------------------
; End of script
; ------------------------------------------------------------------------------

ol_scriptEnd macro
	dc.w	-1
	endm

; ------------------------------------------------------------------------------
; Draw text
; ------------------------------------------------------------------------------

ol_scriptText macro
	dc.w	ol_SCRIPT_TEXT
	endm

; ------------------------------------------------------------------------------
; End of text
; ------------------------------------------------------------------------------

ol_scriptTextEnd macro
	dc.b	0
	even
	endm

; ------------------------------------------------------------------------------
; Wait for user
; ------------------------------------------------------------------------------

ol_scriptWaitUser macro
	dc.w	ol_SCRIPT_WAIT_USER
	endm

; ------------------------------------------------------------------------------
; Show textbox
; ------------------------------------------------------------------------------

ol_scriptShowTextbox macro
	dc.w	ol_SCRIPT_SHOW_TEXTBOX
	endm

; ------------------------------------------------------------------------------
; Hide textbox
; ------------------------------------------------------------------------------

ol_scriptHideTextbox macro
	dc.w	ol_SCRIPT_HIDE_TEXTBOX
	endm

; ------------------------------------------------------------------------------
; Clear textbox
; ------------------------------------------------------------------------------

ol_scriptClearTextbox macro
	dc.w	ol_SCRIPT_CLEAR_TEXTBOX
	endm

; ------------------------------------------------------------------------------
; Show icon
; ------------------------------------------------------------------------------
; ARGUMENTS:
;	data - Icon data address
;	anim - Animation ID
; ------------------------------------------------------------------------------

ol_scriptShowIcon macro data, anim
	dc.w	ol_SCRIPT_SHOW_ICON
	dc.w	anim
	dc.l	data
	endm

; ------------------------------------------------------------------------------
; Hide icon
; ------------------------------------------------------------------------------

ol_scriptHideIcon macro char, anim
	dc.w	ol_SCRIPT_HIDE_ICON
	endm

; ------------------------------------------------------------------------------