; ------------------------------------------------------------------------------
; Script command IDs
; ------------------------------------------------------------------------------

	phase 0
ol_SCRIPT_TEXT:		ds.b 1					; Draw text
ol_SCRIPT_WAIT_USER:	ds.b 1					; Wait for user
ol_SCRIPT_SHOW_TEXTBOX:	ds.b 1					; Show textbox
ol_SCRIPT_HIDE_TEXTBOX:	ds.b 1					; Hide textbox
ol_SCRIPT_SET_ICON:	ds.b 1					; Set icon
	dephase

; ------------------------------------------------------------------------------
; End of script
; ------------------------------------------------------------------------------

ol_scriptEnd macro
	dc.w	-1
	endm

; ------------------------------------------------------------------------------
; Draw text
; ------------------------------------------------------------------------------

ol_scriptText macro
	dc.w	ol_SCRIPT_TEXT
	endm

; ------------------------------------------------------------------------------
; Define text
; ------------------------------------------------------------------------------
; ARGUMENTS:
;	text - Text to draw
; ------------------------------------------------------------------------------

ol_text macro text
	dc.b	text
	endm

; ------------------------------------------------------------------------------
; Define new line in text
; ------------------------------------------------------------------------------

ol_textNewLine macro
	dc.b	-1
	endm

; ------------------------------------------------------------------------------
; Define end of text
; ------------------------------------------------------------------------------

ol_textEnd macro
	dc.b	0
	even
	endm

; ------------------------------------------------------------------------------
; Wait for user
; ------------------------------------------------------------------------------

ol_scriptWaitUser macro
	dc.w	ol_SCRIPT_WAIT_USER
	endm

; ------------------------------------------------------------------------------
; Show textbox
; ------------------------------------------------------------------------------

ol_scriptShowTextbox macro
	dc.w	ol_SCRIPT_SHOW_TEXTBOX
	endm

; ------------------------------------------------------------------------------
; Hide textbox
; ------------------------------------------------------------------------------

ol_scriptHideTextbox macro
	dc.w	ol_SCRIPT_HIDE_TEXTBOX
	endm

; ------------------------------------------------------------------------------
; Hide icon
; ------------------------------------------------------------------------------

ol_scriptHideIcon macro
	dc.w	ol_SCRIPT_SET_ICON
	dc.w	-1, -1
	endm

; ------------------------------------------------------------------------------
; Set icon
; ------------------------------------------------------------------------------
; ARGUMENTS:
;	char - Character ID
;	anim - Animation ID
; ------------------------------------------------------------------------------

ol_scriptSetIcon macro char, anim
	dc.w	ol_SCRIPT_SET_ICON
	dc.w	char, anim
	endm

; ------------------------------------------------------------------------------